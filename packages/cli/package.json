{
  "name": "@tinycloud/cli",
  "version": "0.2.0",
  "description": "TinyCloud CLI - manage data, delegations, and nodes from the terminal",
  "author": "TinyCloud, Inc.",
  "license": "EGPL",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "tc": "./bin/tc"
  },
  "files": [
    "dist",
    "bin"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "dev": "tsup --watch",
    "test:e2e": "bun test test/e2e/",
    "test:e2e:vars": "bun test test/e2e/vars.test.ts",
    "test:e2e:secrets": "bun test test/e2e/secrets.test.ts",
    "test:e2e:vault": "bun test test/e2e/vault.test.ts",
    "test:e2e:node": "bun test test/e2e/node.test.ts",
    "test:e2e:profile": "bun test test/e2e/profile.test.ts",
    "test:e2e:doctor": "bun test test/e2e/doctor.test.ts",
    "test:e2e:init": "bun test test/e2e/init.test.ts",
    "test:e2e:delegation": "bun test test/e2e/delegation.test.ts",
    "test:e2e:kv": "bun test test/e2e/kv.test.ts",
    "test:e2e:errors": "bun test test/e2e/errors.test.ts",
    "test:e2e:agent-secrets": "bun test test/e2e/agent-secrets.test.ts"
  },
  "dependencies": {
    "@tinycloud/node-sdk": "workspace:*",
    "@tinycloud/node-sdk-wasm": "workspace:*",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "open": "^10.0.0",
    "ora": "^8.0.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
